{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://memory-map-production.up.railway.app/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
